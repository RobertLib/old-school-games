# Database connection string (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/old_school_games

# Express session secret — use a long random string in production
SESSION_SECRET=change-me-to-a-long-random-secret

# Application environment: development | production | test
NODE_ENV=development

# Port the server listens on (optional, defaults to 3000)
PORT=3000

# IndexNow API key for search engine URL submission (optional)
INDEXNOW_KEY=

# Public site URL used for building absolute URLs submitted to IndexNow
SITE_URL=https://oldschoolgames.eu
