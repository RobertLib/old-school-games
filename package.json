    "compression": "^1.8.1",
    "connect-pg-simple": "^10.0.0",
    "dompurify": "^3.3.3",
    "ejs": "^5.0.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "jsdom": "^29.0.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@flydotio/dockerfile": "^0.7.10",
    "@types/compression": "^1.8.1",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express": "^5.0.6",
    "@types/jsdom": "^28.0.1",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "nodemon": "^3.1.14",
