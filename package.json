  "main": "index.ts",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "dev": "node --env-file=.env ./node_modules/nodemon/bin/nodemon.js index.ts",
    "start": "node index.ts",
    "migrate": "node --env-file=.env migrate.ts 2>/dev/null || node migrate.ts",
    "format:ejs": "find views -name '*.ejs' -exec npx js-beautify --type html --indent-size 2 --end-with-newline --content_unformatted 'script' -r {} \\;"
  },
  "keywords": [],
