<aside class="left-sidebar">
  <header>Genres</header>
  <ul class="nav nav-column">
    <li>
      <a class="nav-link" href="/">All Genres</a>
    </li>
    <% gameGenres.map(genre => { %>
    <li>
      <a class="nav-link <%= genre.toLowerCase() === req.params.genre ? 'active' : '' %>" href="/<%= genre.toLowerCase() %>">
        <%= genre.charAt(0) %><%= genre.slice(1).toLowerCase() %>
      </a>
    </li>
    <% }); %>
  </ul>

  <br />

  <header>Browse by</header>
  <ul class="nav nav-column">
    <li>
      <a class="nav-link <%= req.path === '/developers' ? 'active' : '' %>" href="/developers">
        All Developers
      </a>
    </li>
    <li>
      <a class="nav-link <%= req.path === '/publishers' ? 'active' : '' %>" href="/publishers">
        All Publishers
      </a>
    </li>
    <li>
      <a class="nav-link <%= req.path === '/years' ? 'active' : '' %>" href="/years">
        Browse by Year
      </a>
    </li>
  </ul>

  <br />

  <header>Top Lists</header>
  <ul class="nav nav-column">
    <li>
      <a class="nav-link <%= req.path === '/game-lists' ? 'active' : '' %>" href="/game-lists">
        All Game Lists
      </a>
    </li>
    <li>
      <a class="nav-link <%= req.path === '/top-dos-games' ? 'active' : '' %>" href="/top-dos-games">
        Top DOS Games
      </a>
    </li>
    <li>
      <a class="nav-link <%= req.path === '/dos-games-1990s' ? 'active' : '' %>" href="/dos-games-1990s">
        Best of the 90s
      </a>
    </li>
    <li>
      <a class="nav-link <%= req.path === '/dos-games-1980s' ? 'active' : '' %>" href="/dos-games-1980s">
        Best of the 80s
      </a>
    </li>
  </ul>
</aside>
