<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('../head') %>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>OldSchoolGames</title>
    <link rel="stylesheet" href="/css/style.css" />
    <meta name="description" content="OldSchoolGames" />
    <meta name="keywords" content="games, retro, oldschool" />
  </head>
  <body class="layout">
    <%- include('../navbar') %>
    <%- include('../sidebar') %>
    <main>
      <a href="/">&lt; Back</a>
      <h1><%= game.title %></h1>
      <p><%= game.description %></p>
      <p>Genre: <%= game.genre %></p>
      <p>
        <% game.images.filter(Boolean).forEach((image) => { %>
        <a href="<%= image %>" target="_blank">
          <img src="<%= image %>" alt="<%= game.title %>" width="320" />
        </a>
        <% }); %>
      </p>
      <p><%- game.stream %></p>
      <p><button id="fullscreen-btn" type="button">Fullscreen</button></p>
      <h2>Comments</h2>
      <%- include('../comments/comment-list') %>
      <h2>New Comment</h2>
      <%- include('../comments/comment-form') %>
    </main>
    <script>
      const fullscreenBtn = document.getElementById("fullscreen-btn");
      fullscreenBtn.addEventListener("click", () => {
        const iframe = document.querySelector("iframe");
        iframe.requestFullscreen();
        iframe.focus();
      });
    </script>
  </body>
</html>
