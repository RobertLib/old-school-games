<div class="game-filters">
  <h2 class="text-lg" style="margin: 0">
    <% if (locals.genre) { %>
    Games in the "<%= genre %>" genre
    <% } else { %>
      <% if (req.query.orderBy === "createdAt") { %>
      Recently added games
      <% } else if (req.query.orderBy === "release") { %>
      Games by release year
      <% } else { %>
      Games of all genres
      <% } %>
    <% } %>
  </h2>
  <ul>
    <li>
      <a
        aria-label="Order by ASC"
        class="inline-block hover-scale <%= !req.query.orderDir || req.query.orderDir === "ASC" ? "active" : "" %>"
        href="?<%= new URLSearchParams({ ...req.query, orderDir: "ASC" }).toString() %>"
        title="Order by ASC"
      >
        ▲
      </a>
    </li>
    <li>
      <a
        aria-label="Order by DESC"
        class="inline-block hover-scale <%= req.query.orderDir === "DESC" ? "active" : "" %>"
        href="?<%= new URLSearchParams({ ...req.query, orderDir: "DESC" }).toString() %>"
        title="Order by DESC"
      >
        ▼
      </a>
    </li>
  </ul>
</div>
