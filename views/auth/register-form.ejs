<form action="/register" method="POST">
  <% if (locals.error) { %>
  <p><%= error %></p>
  <% } %>
  <p>
    <label for="email">Email *</label><br />
    <input
      autocomplete="email"
      id="email"
      maxlength="255"
      name="email"
      required
      type="text"
    />
  </p>
  <p>
    <label for="password">Password *</label><br />
    <input
      autocomplete="new-password"
      id="password"
      maxlength="255"
      name="password"
      required
      type="password"
    />
  </p>
  <p>
    <label for="confirm-password">Confirm password *</label><br />
    <input
      autocomplete="new-password"
      id="confirm-password"
      maxlength="255"
      name="confirmPassword"
      required
      type="password"
    />
  </p>
  <button type="submit">Register</button> | <a href="/">Back</a>
</form>
