<form id="comment-form">
  <input name="gameId" type="hidden" value="<%= game.id %>" />
  <p>
    <label for="nick">Nick</label><br />
    <input id="nick" maxlength="255" name="nick" type="text" />
  </p>
  <p>
    <label for="content">Content *</label><br />
    <textarea
      id="content"
      maxlength="1000"
      name="content"
      required
      rows="10"
    ></textarea>
  </p>
  <button type="submit">Create Comment</button>
</form>

<script>
  document
    .getElementById("comment-form")
    .addEventListener("submit", function (event) {
      event.preventDefault();

      const nick = event.target.nick.value;
      const content = event.target.content.value;
      const gameId = event.target.gameId.value;

      fetch("/comments", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({ nick, content, gameId }),
      })
        .then((response) => response.text())
        .then((data) => {
          document
            .getElementById("comment-list")
            .insertAdjacentHTML("beforeend", data);

          document.getElementById("no-comments")?.remove();

          event.target.reset();
        })
        .catch((error) => {
          console.error("Error:", error);
        });
    });
</script>
