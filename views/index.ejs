<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('head') %>
  <meta name="description" content="<%= locals.description || 'Discover and play hundreds of classic MS-DOS games from the 80s and 90s directly in your browser. Experience retro gaming at its finest with DOSBox emulation!' %>" />
  <title><%= locals.title || 'OldSchoolGames - Play classic MS-DOS Games Online' %></title>
  <!-- Open Graph -->
  <meta property="og:title" content="<%= locals.title || 'OldSchoolGames - Play classic MS-DOS Games Online' %>" />
  <meta property="og:description" content="<%= locals.description || 'Discover and play hundreds of classic MS-DOS games from the 80s and 90s directly in your browser. Experience retro gaming at its finest with DOSBox emulation!' %>" />
  <meta property="og:image" content="<%= locals.image || 'https://oldschoolgames.eu/images/navbar.webp' %>" />
  <meta property="og:url" content="<%= locals.url || req.protocol + '://' + req.get('host') + req.originalUrl %>" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="OldSchoolGames" />
  <script src="/js/rating-stars.js"></script>
  <script src="/js/carousel.js"></script>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": <%- JSON.stringify(locals.title || 'OldSchoolGames - Play classic MS-DOS Games Online') %>,
      "description": <%- JSON.stringify(locals.description || 'Discover and play hundreds of classic MS-DOS games from the 80s and 90s directly in your browser. Experience retro gaming at its finest with DOSBox emulation!') %>,
      "url": "<%= locals.url || req.protocol + '://' + req.get('host') + req.originalUrl %>",
      "mainEntity": {
        "@type": "ItemList",
        "itemListElement": [
          <% games.slice(0, 10).forEach((game, index) => { %>
          {
            "@type": "ListItem",
            "position": <%= index + 1 %>,
            "item": {
              "@type": "VideoGame",
              "name": <%- JSON.stringify(game.title) %>,
              "genre": <%- JSON.stringify(game.genre) %>,
              "gamePlatform": "MS-DOS",
              "url": "https://oldschoolgames.eu/<%= game.slug %>"
            }
          }<%= index < Math.min(games.length - 1, 9) ? ',' : '' %>
          <% }); %>
        ]
      }
    }
  </script>
</head>

<body class="layout">
  <%- include('navbar') %>
  <%- include('left-sidebar') %>
  <main>
    <div class="container">
      <%- include('flash') %>
      <section>
        <% if (req.originalUrl === '/' || req.originalUrl === '') { %>
        <h1 class="text-lg" style="margin: 0 0 7px">Welcome to Old School Games!</h1>
        <div class="ticker-wrap" aria-hidden="true">
          <span class="ticker">👋 Welcome to our portal dedicated to the golden age of gaming! Relive the nostalgia and immerse yourself in the magic of classic games from the MS-DOS era that shaped the world of gaming. Here, you can easily play these timeless classics directly in your browser, without any complicated setup. Just click and let yourself be transported back to a time when games were crafted with heart and soul. Get ready for an adventure filled with pixelated graphics, unforgettable music, and a unique atmosphere. Welcome back to the past! 💾🕹️👾</span>
        </div>

        <!-- Game of the Week and Latest News side by side -->
        <div class="homepage-features">
          <%- include('game-of-the-week') %>
          <%- include('news/news-preview') %>
        </div>

        <!-- Featured Games Carousel -->
        <%- include('featured-games-carousel') %>

        <hr />
        <% } %>
        <% if (req.session?.user?.role === "ADMIN") { %>
        <div class="text-right" style="margin-bottom: 25px; display: flex; gap: 10px; justify-content: flex-end; align-items: center;">
          <a class="btn btn-outline" href="/games/new">+ Add a new game</a>
          <a class="btn btn-outline" href="/news/new">+ Add news</a>
        </div>
        <% } %>
        <% if (req.originalUrl === '/' || req.originalUrl === '') { %>
        <% } else if (locals.letter) { %>
        <h1 class="text-xl" style="margin: 0 0 17px">MS-DOS Games Starting with '<%= letter.toUpperCase() %>'</h1>
        <% } else if (locals.genre) { %>
        <h1 class="text-xl" style="margin: 0 0 12px">Classic MS-DOS <%= genre.charAt(0).toUpperCase() + genre.slice(1).toLowerCase() %> Games</h1>
        <% if (locals.genreBlurb) { %>
        <div style="margin-bottom: 1.5em; padding: 1em; background: rgba(var(--border-rgb), 0.15); border-left: 3px solid rgb(var(--primary-rgb)); border-radius: var(--border-radius);">
          <p style="margin: 0; line-height: 1.7; color: rgb(var(--color-rgb))"><%= genreBlurb %></p>
        </div>
        <% } %>
        <% } else if (locals.year) { %>
        <h1 class="text-xl" style="margin: 0 0 12px">Classic MS-DOS Games from <%= locals.year %></h1>
        <% if (locals.yearBlurb) { %>
        <div style="margin-bottom: 1.5em; padding: 1em; background: rgba(var(--border-rgb), 0.15); border-left: 3px solid rgb(var(--primary-rgb)); border-radius: var(--border-radius);">
          <p style="margin: 0; line-height: 1.7; color: rgb(var(--color-rgb))"><%= yearBlurb %></p>
        </div>
        <% } %>
        <% } else if (locals.developer) { %>
        <h1 class="text-xl" style="margin: 0 0 12px">MS-DOS Games by <%= locals.developer %></h1>
        <% if (locals.studioBlurb) { %>
        <div style="margin-bottom: 1.5em; padding: 1em; background: rgba(var(--border-rgb), 0.15); border-left: 3px solid rgb(var(--primary-rgb)); border-radius: var(--border-radius);">
          <p style="margin: 0; line-height: 1.7; color: rgb(var(--color-rgb))"><%= studioBlurb %></p>
        </div>
        <% } %>
        <% } else if (locals.publisher) { %>
        <h1 class="text-xl" style="margin: 0 0 12px">MS-DOS Games published by <%= locals.publisher %></h1>
        <% if (locals.studioBlurb) { %>
        <div style="margin-bottom: 1.5em; padding: 1em; background: rgba(var(--border-rgb), 0.15); border-left: 3px solid rgb(var(--primary-rgb)); border-radius: var(--border-radius);">
          <p style="margin: 0; line-height: 1.7; color: rgb(var(--color-rgb))"><%= studioBlurb %></p>
        </div>
        <% } %>
        <% } else { %>
        <h1 class="text-xl" style="margin: 0 0 17px">All games</h1>
        <% } %>
        <%- include('games/alphabet-filter') %>
        <%- include('games/game-filters') %>

        <!-- Contextual Links for filtered pages -->
        <% if (locals.publisher || locals.developer || locals.year) { %>
        <div style="margin: 20px 0; padding: 15px; background: rgba(var(--border-rgb), 0.2); border: 1px solid rgb(var(--border-rgb)); border-radius: var(--border-radius); color: rgb(var(--color-rgb));">
          <h3 style="margin: 0 0 10px; color: rgb(var(--primary-rgb)); text-shadow: var(--text-shadow);">Related:</h3>
          <div style="display: flex; flex-wrap: wrap; gap: 10px;">
            <% if (locals.publisher) { %>
            <a href="/publishers" class="btn btn-sm btn-outline">All Publishers</a>
            <% if (locals.year) { %><a href="/year/<%= locals.year %>" class="color-primary underline">Games from <%= locals.year %></a><% } %>
            <% } %>
            <% if (locals.developer) { %>
            <a href="/developers" class="btn btn-sm btn-outline">All Developers</a>
            <% if (locals.year) { %><a href="/year/<%= locals.year %>" class="color-primary underline">Games from <%= locals.year %></a><% } %>
            <% } %>
            <% if (locals.year) { %>
            <a href="/years" class="btn btn-sm btn-outline">All Years</a>
            <%
                const prevYear = locals.year - 1;
                const nextYear = locals.year + 1;
                const validYears = locals.allYears || [];
              %>
            <% if (validYears.includes(prevYear)) { %><a href="/year/<%= prevYear %>" class="color-primary underline"><%= prevYear %></a><% } %>
            <% if (validYears.includes(nextYear)) { %><a href="/year/<%= nextYear %>" class="color-primary underline"><%= nextYear %></a><% } %>
            <% } %>
            <a href="/" class="btn btn-sm btn-outline">All Games</a>
          </div>
        </div>
        <% } %>

        <%- include('games/game-list') %>
      </section>
    </div>
  </main>
  <%- include('right-sidebar') %>
  <%- include('footer') %>
</body>

</html>
