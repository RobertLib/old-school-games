<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>OldSchoolGames</title>
    <link rel="stylesheet" href="/css/style.css" />
    <meta name="description" content="OldSchoolGames" />
    <meta name="keywords" content="games, retro, oldschool" />
  </head>
  <body>
    <%- include('navbar', { session }) %>
    <main>
      <h1>OldSchoolGames</h1>
      <a href="/login">Login</a>
      <a href="/register">Register</a>
      <hr />
      <% if (session.user?.role === "ADMIN") { %>
      <a href="/games/new">Add a new game</a>
      <% } %>
      <% if (message) { %>
      <p><%= message %></p>
      <% } %>
      <%- include('games/game-list', { games, session }) %>
    </main>
  </body>
</html>
