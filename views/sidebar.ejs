<nav class="sidebar">
  <ul>
    <li>
      <a href="/">All Genres</a>
    </li>
    <% gameGenres.map(genre => { %>
    <li>
      <a href="/?genre=<%= genre %>" style="<%= genre === query.genre ? "text-decoration: underline" : "" %>">
        <%= genre.charAt(0) %><%= genre.slice(1).toLowerCase() %>
      </a>
    </li>
    <% }); %>
  </ul>
</nav>
